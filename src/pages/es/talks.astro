---
import Base from '@/layouts/Base.astro';

const lang = 'es' as const;

// Add talks here as { title, event, date, href, description }
const talks: { title: string; event: string; date: string; href?: string; description?: string }[] = [];
---

<Base
  title="Charlas — Miguel Valdes"
  description="Charlas y presentaciones de Miguel Valdes sobre observabilidad, ingeniería de plataformas y más."
  lang={lang}
>
  <article class="prose">
    <h1>Charlas</h1>
    <p>Presentaciones, charlas en conferencias y sesiones grabadas. Más próximamente.</p>

    {talks.length === 0 ? (
      <p class="placeholder-note">Nada por aquí todavía — vuelve pronto.</p>
    ) : (
      <ul class="talk-list">
        {talks.map((talk) => (
          <li class="talk-item">
            <div class="talk-meta">{talk.date} · {talk.event}</div>
            {talk.href
              ? <a href={talk.href} target="_blank" rel="noopener" class="talk-title">{talk.title}</a>
              : <span class="talk-title">{talk.title}</span>
            }
            {talk.description && <p class="talk-desc">{talk.description}</p>}
          </li>
        ))}
      </ul>
    )}
  </article>
</Base>
