---
import Base from '@/layouts/Base.astro';

const lang = 'en' as const;

// Add projects here as { name, description, repo, blogSlug, tags, status }
const projects: { name: string; description: string; repo?: string; blogSlug?: string; tags?: string[]; status?: string }[] = [
  {
    name: "doit",
    description: "A self-hosted task manager with NLP parsing, calendar sync, keyboard shortcuts, and multi-user support. Built in a week with Claude. Replaced my Todoist subscription.",
    repo: "https://github.com/mvaldes14/task-manager",
    blogSlug: "task-manager-blog",
    tags: ["go", "react", "otel", "self-hosted"],
    status: "active",
  },
  {
    name: "meal-notifier",
    description: "Go script that hits the school district meal API every weekday morning and fires a Telegram notification with breakfast and lunch. Runs as a Kubernetes CronJob on the homelab.",
    repo: "https://github.com/mvaldes14/meal-notifier",
    blogSlug: "meal-notifier",
    tags: ["go", "kubernetes", "telegram", "automation"],
    status: "active",
  },
  {
    name: "terraform.nvim",
    description: "Neovim plugin for Terraform — run plans in a floating window and fuzzy-browse the entire state with Telescope. First plugin I shipped; led to a merged PR in nvim-lint.",
    repo: "https://github.com/mvaldes14/terraform.nvim",
    blogSlug: "terraform-nvim",
    tags: ["lua", "neovim", "terraform", "iac"],
    status: "active",
  },
  {
    name: "asdf-tea",
    description: "asdf plugin for tea, the Gitea CLI. Handles binary download and path setup so you can manage the Gitea CLI the same way as any other asdf-managed tool.",
    repo: "https://github.com/mvaldes14/asdf-tea",
    blogSlug: "asdf-tea",
    tags: ["bash", "asdf", "gitea", "tooling"],
    status: "active",
  },
  {
    name: "babylog",
    description: "PWA baby tracker built with Vue and Firebase for tracking feeds, diapers, and stats across two sleep-deprived parents' phones. Served its purpose for the first few weeks after our daughter arrived.",
    repo: "https://github.com/mvaldes14/babylog",
    blogSlug: "babylog-app",
    tags: ["vue", "firebase", "pwa"],
    status: "archived",
  },
];
---

<Base
  title="Projects — Miguel Valdes"
  description="Things I've built — tools, homelab projects, open source, and experiments."
  lang={lang}
>
  <article class="prose">
    <h1>Projects</h1>
    <p>Things I've built — tools, homelab infrastructure, open source contributions, and experiments.</p>

    {projects.length === 0 ? (
      <p class="placeholder-note">Nothing here yet — check back soon.</p>
    ) : (
      <ul class="project-list">
        {projects.map((project) => (
          <li class="project-item">
            <div class="project-header">
              {project.blogSlug
                ? <a href={`/en/posts/${project.blogSlug}`} class="project-name">{project.name}</a>
                : <span class="project-name">{project.name}</span>
              }
              {project.status && <span class={`project-status ${project.status}`}>{project.status}</span>}
              <div class="project-links">
                {project.repo && (
                  <a href={project.repo} target="_blank" rel="noopener" class="project-link-repo" title="View on GitHub">
                    <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                      <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
                    </svg>
                  </a>
                )}
              </div>
            </div>
            <p class="project-desc">{project.description}</p>
            {project.tags && project.tags.length > 0 && (
              <div class="project-tags">
                <span class="project-tags-label">stack</span>
                {project.tags.map((tag, i) => (
                  <span class="project-tag">{tag}{i < project.tags!.length - 1 ? ',' : ''}</span>
                ))}
              </div>
            )}
          </li>
        ))}
      </ul>
    )}
  </article>
</Base>
